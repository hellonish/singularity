            "default_audience": "expert",
            "default_output_format": "academic_paper",
            "source_skills": {
                "primary": [
                    "academic_search",
                    "code_search",
                    "dataset_search"
                ],
                "secondary": [
                    "web_search",
                    "video_search",
                    "forum_search"
                ]
