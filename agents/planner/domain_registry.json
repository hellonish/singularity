    "_meta": {
        "version": "2.0",
        "description": "Domain bundles loaded by the Planner in Phase 0. Each domain defines preferred source skills, analysis skills, output skills, quality axes, and audience defaults. The Planner narrows the skill registry to this bundle before constructing the DAG \u2014 preventing skill overload on 36-skill registry.",
        "audience_types": [
            "layperson",
            "student",
            "practitioner",
            "expert",
            "executive"
        ],
        "output_format_types": [
            "academic_paper",
            "legal_brief",
            "systematic_review",
            "investigative_report",
            "executive_brief",
            "policy_brief",
            "technical_report",
            "insights_brief",
