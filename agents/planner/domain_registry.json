            "output_skills": [
                "report_generator",
                "bibliography_gen",
                "visualization_spec"
            ],
            "quality_axes": {
                "universal": [
                    "source_authority",
                    "cross_validation",
                    "recency",
                    "depth",
                    "coverage"
                ],
                "domain_specific": [
                    "replication_status",
                    "methodological_soundness"
                ]
            },
            "rubric_notes": "Prefer arXiv, NeurIPS, ICML, ICLR, ACL for source_authority. recency window: 2 years. Benchmark comparisons require cross_validation across at least 2 independent datasets."
        },
