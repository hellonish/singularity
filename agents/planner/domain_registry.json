    "audience_output_rules": {
        "layperson": {
            "preferred_output_skills": [
                "explainer",
                "exec_summary"
            ],
            "avoid_skills": [
                "bibliography_gen",
                "annotation_gen"
            ],
            "synthesis_instruction": "Avoid jargon. Use analogies. Prioritize 'what does this mean' over 'what the sources say'.",
            "depth_default": "shallow"
        },
        "student": {
            "preferred_output_skills": [
                "report_generator",
                "bibliography_gen",
                "annotation_gen"
            ],
            "avoid_skills": [
                "decision_matrix"
            ],
            "synthesis_instruction": "Explain reasoning. Show how conclusions follow from evidence. Educational tone.",
            "depth_default": "deep"
        },
        "practitioner": {
            "preferred_output_skills": [
                "report_generator",
                "decision_matrix",
                "annotation_gen"
            ],
            "avoid_skills": [
                "explainer"
            ],
            "synthesis_instruction": "Assume domain competence. Focus on actionable findings and trade-offs.",
            "depth_default": "deep"
        },
        "expert": {
            "preferred_output_skills": [
                "report_generator",
                "bibliography_gen",
                "visualization_spec"
            ],
            "avoid_skills": [
                "explainer",
                "exec_summary"
            ],
            "synthesis_instruction": "Maximum technical precision. Full methodological detail. Hedged claims with explicit uncertainty.",
            "depth_default": "deep"
        },
        "executive": {
            "preferred_output_skills": [
                "exec_summary",
                "decision_matrix",
                "visualization_spec"
            ],
            "avoid_skills": [
                "bibliography_gen",
                "annotation_gen",
                "explainer"
            ],
            "synthesis_instruction": "Lead with decision. Bottom line up front. Trade-offs in 3 bullets. No methodology detail unless asked.",
            "depth_default": "shallow"
        }
    },
